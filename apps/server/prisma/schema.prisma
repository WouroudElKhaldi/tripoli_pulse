// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis, pgvector]
}

model User {
  id              String             @id @default(uuid())
  email           String             @unique
  phone           String?            @unique
  passwordHash    String
  role            UserRole           @default(CITIZEN)
  language        Language           @default(EN)
  theme           Theme              @default(SYSTEM)
  emailVerified   Boolean            @default(false)
  phoneVerified   Boolean            @default(false)
  isActive        Boolean            @default(true)
  isDeleted       Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  profile         UserProfile?
  sessions        Session[]
  reports         Report[]
  notifications   Notification[]
  donations       Donation[]
  deviceTokens    DeviceToken[]
  companion       Companion?
  assignedReports ReportAssignment[]
  votes           ReportVote[]
  comments        ReportComment[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([createdAt])
}

model UserProfile {
  id             String    @id @default(uuid())
  userId         String    @unique
  firstName      String
  lastName       String
  avatarUrl      String?
  birthDate      DateTime?
  districtId     String?
  neighborhoodId String?

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String // e.g. "ios", "android", "web"
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model District {
  id            String         @id @default(uuid())
  nameEn        String         @unique
  nameAr        String
  neighborhoods Neighborhood[]
  reports       Report[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Neighborhood {
  id         String             @id @default(uuid())
  districtId String
  nameEn     String
  nameAr     String

  district   District           @relation(fields: [districtId], references: [id], onDelete: Cascade)
  reports    Report[]
  score      NeighborhoodScore?

  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([districtId])
}

model Report {
  id             String                @id @default(uuid())
  userId         String
  districtId     String?
  neighborhoodId String?

  title          String
  description    String
  category       ReportCategory
  priority       ReportPriority
  status         ReportStatus          @default(PENDING)

  latitude       Decimal?              @db.Decimal(10, 7)
  longitude      Decimal?              @db.Decimal(10, 7)

  aiSummary      String?
  aiSeverity     Int?

  resolvedAt     DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  district       District?             @relation(fields: [districtId], references: [id], onDelete: SetNull)
  neighborhood   Neighborhood?         @relation(fields: [neighborhoodId], references: [id], onDelete: SetNull)

  images         ReportImage[]
  comments       ReportComment[]
  statusHistory  ReportStatusHistory[]
  votes          ReportVote[]
  assignment     ReportAssignment?
  analyses       AiAnalysis[]

  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([priority])
  @@index([districtId])
  @@index([neighborhoodId])
  @@index([createdAt])
  @@index([latitude, longitude])
}

model ReportImage {
  id        String   @id @default(uuid())
  reportId  String
  url       String
  width     Int?
  height    Int?

  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([reportId])
}

model ReportComment {
  id        String   @id @default(uuid())
  reportId  String
  userId    String
  message   String

  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([reportId])
  @@index([userId])
}

model ReportStatusHistory {
  id          String       @id @default(uuid())
  reportId    String
  changedById String
  oldStatus   ReportStatus
  newStatus   ReportStatus
  note        String?

  report      Report       @relation(fields: [reportId], references: [id], onDelete: Cascade)

  createdAt   DateTime     @default(now())

  @@index([reportId])
  @@index([changedById])
}

model ReportVote {
  id        String   @id @default(uuid())
  reportId  String
  userId    String

  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([reportId, userId])
  @@index([reportId])
  @@index([userId])
}

model ReportAssignment {
  id           String           @id @default(uuid())
  reportId     String           @unique
  assignedToId String?
  status       AssignmentStatus @default(PENDING)
  notes        String?
  assignedAt   DateTime         @default(now())
  completedAt  DateTime?

  report       Report           @relation(fields: [reportId], references: [id], onDelete: Cascade)
  assignedTo   User?            @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([assignedToId])
}

model Campaign {
  id           String         @id @default(uuid())
  title        String
  description  String
  targetAmount Decimal        @db.Decimal(12, 2)
  raisedAmount Decimal        @default(0) @db.Decimal(12, 2)
  status       CampaignStatus @default(DRAFT)
  startsAt     DateTime
  endsAt       DateTime

  donations    Donation[]

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status])
}

model Donation {
  id         String   @id @default(uuid())
  userId     String
  campaignId String
  amount     Decimal  @db.Decimal(12, 2)

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  payment    Payment?

  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([campaignId])
}

model Payment {
  id            String          @id @default(uuid())
  donationId    String          @unique
  provider      PaymentProvider
  status        PaymentStatus   @default(PENDING)
  transactionId String?         @unique
  amount        Decimal         @db.Decimal(12, 2)

  donation      Donation        @relation(fields: [donationId], references: [id], onDelete: Cascade)

  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([status])
}

model Companion {
  id         String                  @id @default(uuid())
  userId     String                  @unique
  name       String?
  level      Int                     @default(1)
  experience Int                     @default(0)
  happiness  Int                     @default(100)

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievements UserAchievement[]
  transactions ExperienceTransaction[]

  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}

model UserAchievement {
  id            String    @id @default(uuid())
  companionId   String
  achievementId String // e.g. "FIRST_REPORT", "CAMPAIGN_HERO"
  unlockedAt    DateTime  @default(now())

  companion     Companion @relation(fields: [companionId], references: [id], onDelete: Cascade)

  @@unique([companionId, achievementId])
  @@index([companionId])
}

model ExperienceTransaction {
  id          String    @id @default(uuid())
  companionId String
  amount      Int
  reason      String // e.g. "Report resolved", "Daily check-in"
  createdAt   DateTime  @default(now())

  companion   Companion @relation(fields: [companionId], references: [id], onDelete: Cascade)

  @@index([companionId])
}

model NeighborhoodScore {
  id                  String       @id @default(uuid())
  neighborhoodId      String       @unique
  score               Int
  safetyScore         Int
  cleanlinessScore    Int
  infrastructureScore Int

  neighborhood        Neighborhood @relation(fields: [neighborhoodId], references: [id], onDelete: Cascade)

  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model AiAnalysis {
  id         String   @id @default(uuid())
  reportId   String
  modelName  String
  summary    String?
  category   String?
  severity   Int?
  confidence Float?

  report     Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@index([reportId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  body      String
  type      NotificationType
  isRead    Boolean          @default(false)

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
}

enum UserRole {
  CITIZEN
  MUNICIPALITY_STAFF
  NGO
  ADMIN
  SUPER_ADMIN
}

enum Language {
  EN
  AR
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

enum ReportCategory {
  INFRASTRUCTURE
  WASTE_MANAGEMENT
  STREET_LIGHTING
  WATER_SANITATION
  ROADS_TRAFFIC
  PUBLIC_SAFETY
  ENVIRONMENTAL
  OTHER
}

enum ReportPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ReportStatus {
  PENDING
  VERIFIED
  ASSIGNED
  UNDER_REVIEW
  IN_PROGRESS
  RESOLVED
  REJECTED
}

enum AssignmentStatus {
  PENDING
  ACCEPTED
  COMPLETED
  CANCELLED
}

enum NotificationType {
  REPORT_STATUS_CHANGE
  NEW_COMMENT
  CAMPAIGN_UPDATE
  ACHIEVEMENT_UNLOCKED
  GENERAL
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PaymentProvider {
  AREEBA
  STRIPE
  OTHER
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}