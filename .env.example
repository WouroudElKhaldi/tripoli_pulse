# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tripoli_pulse?schema=public"

# Redis Configuration
REDIS_HOST="localhost"
REDIS_PORT=6379

# JWT Secrets
JWT_SECRET="super-secret-key-change-in-production"
JWT_REFRESH_SECRET="super-secret-refresh-key-change-in-production"

# Cloudinary Configuration
CLOUDINARY_NAME="your_cloudinary_name"
CLOUDINARY_KEY="your_cloudinary_key"
CLOUDINARY_SECRET="your_cloudinary_secret"

# Maps Configuration
OPENSTREETMAP_URL="https://www.openstreetmap.org"
MAP_TILE_URL="https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png"

# Areeba Payment Gateway Configuration
AREEBA_BASE_URL="https://merchant.areeba.com"
AREEBA_MERCHANT_ID="your_merchant_id"
AREEBA_API_KEY="your_areeba_api_key"

# Ollama AI Configuration
OLLAMA_BASE_URL="http://localhost:11434"
